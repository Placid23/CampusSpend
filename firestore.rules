rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    // --- COLLECTION RULES ---

    /**
     * @path /userProfiles/{uid}
     * Users can manage their own profile.
     */
    match /userProfiles/{uid} {
      allow read, write: if isOwner(uid);
    }

    /**
     * @path /vendors/{vendorId}
     * Publicly readable by students. Managed by vendor users.
     */
    match /vendors/{vendorId} {
      allow read: if signedIn();
      allow write: if signedIn() && (
        (request.method == 'create' && request.resource.data.userId == request.auth.uid) ||
        (resource.data.userId == request.auth.uid)
      );
    }

    /**
     * @path /products/{productId}
     * Marketplace is public to all students. Vendors manage their own.
     */
    match /products/{productId} {
      allow read: if signedIn();
      allow write: if signedIn() && (
        (request.method == 'create' && request.resource.data.vendorOwnerId == request.auth.uid) ||
        (resource.data.vendorOwnerId == request.auth.uid)
      );
    }

    /**
     * @path /users/{uid}/orders/{orderId}
     * Student's private order collection.
     */
    match /users/{uid}/orders/{orderId} {
      allow read, write: if isOwner(uid);
      
      match /orderItems/{itemId} {
        allow read, write: if isOwner(uid);
      }
    }

    /**
     * @path /users/{uid}/expenses/{expenseId}
     * Student's private spending log.
     */
    match /users/{uid}/expenses/{expenseId} {
      allow read, write: if isOwner(uid);
    }

    /**
     * @path collectionGroup orderItems
     * Allows vendors to see items belonging to them across student orders.
     */
    match /{path=**}/orderItems/{itemId} {
      allow read: if signedIn() && resource.data.vendorOwnerId == request.auth.uid;
    }
  }
}