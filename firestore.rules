rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // --- COLLECTION RULES ---

    /**
     * @path /userProfiles/{userId}
     */
    match /userProfiles/{userId} {
      // Allow creation if the user is signing up as themselves
      // We check the ID matches and the role is valid.
      allow create: if isOwner(userId) 
        && request.resource.data.role in ['student', 'vendor'];
      
      // Owners and Admins can read/update profiles
      allow get: if isOwner(userId) || isAdmin();
      allow update: if isOwner(userId);
      
      // Only admins can list all users or delete them
      allow list, delete: if isAdmin();
    }

    /**
     * @path /vendors/{vendorId}
     * Publicly readable, writeable only by the vendor owner.
     */
    match /vendors/{vendorId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow delete: if isAdmin();
    }

    /**
     * @path /products/{productId}
     * Publicly readable, managed by vendor owners.
     */
    match /products/{productId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.vendorOwnerId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.vendorOwnerId == request.auth.uid;
      allow delete: if (isSignedIn() && resource.data.vendorOwnerId == request.auth.uid) || isAdmin();
    }

    /**
     * @path /users/{studentId}/orders/{orderId}
     * Path-based ownership for orders.
     */
    match /users/{studentId}/orders/{orderId} {
      allow read, write: if isOwner(studentId) || isAdmin();
    }

    /**
     * @path /users/{studentId}/expenses/{expenseId}
     * Path-based ownership for expense tracking.
     */
    match /users/{studentId}/expenses/{expenseId} {
      allow read, write: if isOwner(studentId) || isAdmin();
    }

    /**
     * @path /users/{studentId}/budgets/{budgetId}
     */
    match /users/{studentId}/budgets/{budgetId} {
      allow read, write: if isOwner(studentId) || isAdmin();
    }

    /**
     * @path /roles_admin/{userId}
     */
    match /roles_admin/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}