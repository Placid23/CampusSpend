rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CAMPUSSPEND SECURITY RULES
     * Triggering re-deployment to ensure rules are active.
     */

    // --- HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isDocOwner(ownerField) {
      return isSignedIn() && request.auth.uid == resource.data[ownerField];
    }

    function isNewDocOwner(ownerField) {
      return isSignedIn() && request.auth.uid == request.resource.data[ownerField];
    }

    // --- COLLECTION RULES ---

    /**
     * @path /userProfiles/{userId}
     */
    match /userProfiles/{userId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId) || isAdmin();
      // Explicitly allow creation for the authenticated user matching the document ID
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isExistingOwner(userId);
      allow delete: if isAdmin();
    }

    /**
     * @path /roles_admin/{userId}
     */
    match /roles_admin/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    /**
     * @path /users/{studentId}/orders/{orderId}
     */
    match /users/{studentId}/orders/{orderId} {
      allow get, list: if isOwner(studentId) || isAdmin();
      allow create: if isOwner(studentId);
      allow update: if isExistingOwner(studentId);
      allow delete: if isAdmin();
    }

    /**
     * @path /users/{studentId}/orders/{orderId}/orderItems/{orderItemId}
     */
    match /users/{studentId}/orders/{orderId}/orderItems/{orderItemId} {
      allow get, list: if isOwner(studentId) || isAdmin() || (isSignedIn() && resource.data.vendorOwnerId == request.auth.uid);
      allow create: if isOwner(studentId);
      allow update: if isExistingOwner(studentId) || isAdmin();
      allow delete: if isAdmin();
    }

    /**
     * @path /users/{studentId}/expenses/{expenseId}
     */
    match /users/{studentId}/expenses/{expenseId} {
      allow get, list: if isOwner(studentId) || isAdmin();
      allow create: if isOwner(studentId);
      allow update: if isExistingOwner(studentId);
      allow delete: if isExistingOwner(studentId) || isAdmin();
    }

    /**
     * @path /users/{studentId}/budgets/{budgetId}
     */
    match /users/{studentId}/budgets/{budgetId} {
      allow get, list: if isOwner(studentId) || isAdmin();
      allow create: if isOwner(studentId);
      allow update: if isExistingOwner(studentId);
      allow delete: if isExistingOwner(studentId) || isAdmin();
    }

    /**
     * @path /vendors/{vendorId}
     */
    match /vendors/{vendorId} {
      allow get, list: if true;
      allow create: if isSignedIn() && isNewDocOwner('userId');
      allow update: if isDocOwner('userId');
      allow delete: if isAdmin();
    }

    /**
     * @path /products/{productId}
     */
    match /products/{productId} {
      allow get, list: if true;
      allow create: if isSignedIn() && isNewDocOwner('vendorOwnerId');
      allow update: if isDocOwner('vendorOwnerId');
      allow delete: if isDocOwner('vendorOwnerId') || isAdmin();
    }

    /**
     * @path /categories/{categoryId}
     */
    match /categories/{categoryId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }
  }
}