rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CAMPUSSPEND SECURITY RULES - UPDATED
     * Optimized for high-fidelity role-based access.
     */

    // --- HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // --- COLLECTION RULES ---

    /**
     * @path /userProfiles/{userId}
     * Stores core student/vendor profile data.
     */
    match /userProfiles/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      // Allow creation if the user is signed in and the ID matches their Auth UID
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isOwner(userId);
      allow delete: if isAdmin();
    }

    /**
     * @path /roles_admin/{userId}
     */
    match /roles_admin/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    /**
     * @path /vendors/{vendorId}
     * Publicly readable, writeable only by the owner.
     */
    match /vendors/{vendorId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow delete: if isAdmin();
    }

    /**
     * @path /products/{productId}
     * Publicly readable, managed by vendor owners.
     */
    match /products/{productId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.vendorOwnerId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.vendorOwnerId == request.auth.uid;
      allow delete: if (isSignedIn() && resource.data.vendorOwnerId == request.auth.uid) || isAdmin();
    }

    /**
     * @path /users/{studentId}/orders/{orderId}
     */
    match /users/{studentId}/orders/{orderId} {
      allow read: if isOwner(studentId) || isAdmin();
      allow create: if isOwner(studentId);
      allow update: if isOwner(studentId) || isAdmin();
    }

    /**
     * @path /users/{studentId}/expenses/{expenseId}
     */
    match /users/{studentId}/expenses/{expenseId} {
      allow read: if isOwner(studentId) || isAdmin();
      allow create: if isOwner(studentId);
    }
  }
}