rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---
    function signedIn() {
      return request.auth != null;
    }

    // --- COLLECTION RULES ---

    /**
     * @path /userProfiles/{uid}
     * Users manage their own profile.
     */
    match /userProfiles/{uid} {
      allow read: if signedIn();
      allow create: if signedIn() && request.auth.uid == uid;
      allow update: if signedIn() && request.auth.uid == uid;
    }

    /**
     * @path /vendors/{vendorId}
     * Marketplace discovery. Managed by vendor users.
     */
    match /vendors/{vendorId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if signedIn() && resource.data.userId == request.auth.uid;
    }

    /**
     * @path /products/{productId}
     * Marketplace products. Publicly readable, managed by vendors.
     */
    match /products/{productId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.vendorOwnerId == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.vendorOwnerId == request.auth.uid;
    }

    /**
     * @path /users/{studentId}/*
     * Private student data (orders, expenses, budgets).
     */
    match /users/{studentId}/{document=**} {
      allow read, write: if signedIn() && request.auth.uid == studentId;
    }

    /**
     * @path collectionGroup orderItems
     * CRITICAL: Enables vendors to query their specific sales across all orders.
     * Use where("vendorOwnerId", "==", auth.uid) in the query.
     */
    match /{path=**}/orderItems/{itemId} {
      allow list: if signedIn() && (
        request.auth.uid == resource.data.vendorOwnerId ||
        request.auth.uid == resource.data.studentId
      );
      allow get: if signedIn();
    }
  }
}
