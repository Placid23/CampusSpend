rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    // --- COLLECTION RULES ---

    /**
     * @path /userProfiles/{uid}
     * Users manage their own profile. We allow broad read for role-checking
     * but restrict writes strictly to the owner.
     */
    match /userProfiles/{uid} {
      allow read: if signedIn();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid);
    }

    /**
     * @path /vendors/{vendorId}
     * Marketplace discovery. Managed by vendor users.
     */
    match /vendors/{vendorId} {
      allow read: if signedIn();
      allow write: if signedIn() && (
        (request.method == 'create' && request.resource.data.userId == request.auth.uid) ||
        (resource.data.userId == request.auth.uid)
      );
    }

    /**
     * @path /products/{productId}
     * Marketplace products. Publicly readable, managed by vendors.
     */
    match /products/{productId} {
      allow read: if signedIn();
      allow write: if signedIn() && (
        (request.method == 'create' && request.resource.data.vendorOwnerId == request.auth.uid) ||
        (resource.data.vendorOwnerId == request.auth.uid)
      );
    }

    /**
     * @path /users/{uid}/orders/{orderId}
     * Private student orders and expenses.
     */
    match /users/{uid}/orders/{orderId} {
      allow read, write: if isOwner(uid);
      
      match /orderItems/{itemId} {
        allow read, write: if isOwner(uid);
      }
    }

    match /users/{uid}/expenses/{expenseId} {
      allow read, write: if isOwner(uid);
    }

    /**
     * @path collectionGroup orderItems
     * CRITICAL: This rule enables vendors to query their specific sales across all student orders.
     * The recursive match {path=**} is required for collectionGroup queries.
     */
    match /{path=**}/orderItems/{itemId} {
      allow list: if signedIn() && (
        // Access is granted if the vendorOwnerId in the document matches the logged-in user
        request.auth.uid == resource.data.vendorOwnerId ||
        // Or if the studentId matches (for their own history)
        request.auth.uid == resource.data.studentId
      );
      allow get: if signedIn();
    }
  }
}